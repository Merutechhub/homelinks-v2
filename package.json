{
  "name": "homelink-next-gen",
  "version": "2.0.0",
  "description": "Homelink Next Gen - Serverless, Real-time PWA using Supabase",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "dev": "vite dev --port 5000",
    "build": "vite build",
    "preview": "vite preview",
    "check": "tsc --noEmit",
    "check:deno": "deno check server/edge-functions/*.ts",
    "check:all": "pnpm run check && pnpm run check:deno",
    "lint": "eslint . --ext .ts,.tsx",
    "supabase:gen": "supabase gen types typescript --project-id $SUPABASE_PROJECT_ID > src/types/supabase.ts",
    "prepare": "husky install"
  },
